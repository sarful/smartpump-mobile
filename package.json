{
  "name": "smartpump-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "node scripts/env-check.mjs --mode=dev && expo start",
    "android": "node scripts/env-check.mjs --mode=dev && expo run:android",
    "ios": "node scripts/env-check.mjs --mode=dev && expo run:ios",
    "web": "node scripts/env-check.mjs --mode=dev && expo start --web",
    "typecheck": "tsc --noEmit",
    "release:validate": "npm run typecheck && npm run preflight",
    "build:apk": "node scripts/env-check.mjs --mode=build:apk && eas build --platform android --profile preview",
    "build:aab": "node scripts/env-check.mjs --mode=build:aab && eas build --platform android --profile production",
    "preflight": "node scripts/preflight.mjs",
    "package:codecanyon": "node scripts/prepare-codecanyon.mjs"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.33",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "typescript": "^5.9.2"
  }
}
